    <script>
        const apiKey = ""; // Chave injetada em runtime
        lucide.createIcons();

        // Reveal Logic
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                if (elementTop < windowHeight - 150) reveals[i].classList.add("active");
            }
        }
        window.addEventListener("scroll", reveal);

        // Modais
        function closeModals() {
            document.getElementById('iaModal').style.display = 'none';
            document.getElementById('dicaModal').style.display = 'none';
            document.getElementById('faqModal').style.display = 'none';
        }

        function openIaAssistant() { document.getElementById('iaModal').style.display = 'flex'; }
        function openDicaIa() { document.getElementById('dicaModal').style.display = 'flex'; }
        function toggleFaq() { document.getElementById('faqModal').style.display = 'flex'; }

        // --- GEMINI INTEGRATION: ASSISTENTE IA ✨ ---
        async function askGemini() {
            const input = document.getElementById('userInput');
            const history = document.getElementById('chatHistory');
            const btn = document.getElementById('sendBtn');
            const userText = input.value.trim();

            if (!userText) return;

            // UI Feedback
            input.value = '';
            history.innerHTML += `<div class="text-right"><span class="bg-gray-200 p-2 rounded inline-block mb-2">${userText}</span></div>`;
            const loadingId = 'msg-' + Date.now();
            history.innerHTML += `<div id="${loadingId}" class="bg-blue-50 p-2 rounded mb-2">Pensando... ✨</div>`;
            history.scrollTop = history.scrollHeight;
            btn.disabled = true;

            const systemPrompt = `Você é o Assistente Virtual de Comunicação Interna da SEDEC-MT (Secretaria de Desenvolvimento Econômico de Mato Grosso). 
            Seu objetivo é ajudar servidores a entenderem o Plano de Comunicação 2026/2027 e o Plano de Integridade.
            Contexto: Missão (Crescimento sustentável), Visão (Inovação e Eficiência), Secretário (César Miranda). 
            Seja profissional, institucional e encorajador. Mantenha as respostas curtas e claras.`;

            try {
                let responseText = "";
                let retryCount = 0;
                const delays = [1000, 2000, 4000, 8000, 16000];

                while (retryCount < 5) {
                    try {
                        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                contents: [{ parts: [{ text: userText }] }],
                                systemInstruction: { parts: [{ text: systemPrompt }] }
                            })
                        });
                        const data = await response.json();
                        responseText = data.candidates?.[0]?.content?.parts?.[0]?.text || "Desculpe, não consegui processar isso agora.";
                        break;
                    } catch (e) {
                        await new Promise(res => setTimeout(res, delays[retryCount]));
                        retryCount++;
                    }
                }
                document.getElementById(loadingId).innerText = responseText;
            } catch (err) {
                document.getElementById(loadingId).innerText = "Erro ao conectar. Tente novamente mais tarde.";
            } finally {
                btn.disabled = false;
                history.scrollTop = history.scrollHeight;
            }
        }

        // --- GEMINI INTEGRATION: MELHORAR DICA ✨ ---
        async function improveIdea() {
            const input = document.getElementById('dicaInput');
            const result = document.getElementById('dicaResult');
            const btn = document.getElementById('dicaBtn');
            const idea = input.value.trim();

            if (!idea) return;

            btn.disabled = true;
            btn.innerText = "IA Refinando sua ideia... ✨";
            result.classList.add('hidden');

            const prompt = `Refine esta ideia de um servidor da SEDEC-MT para torná-la uma proposta formal para o Comitê de Integridade e Comunicação. 
            Ideia original: "${idea}". 
            Retorne um parágrafo curto que use termos profissionais e conecte a ideia à "Eficiência" ou "Transparência".`;

            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
                });
                const data = await response.json();
                const refinedText = data.candidates?.[0]?.content?.parts?.[0]?.text;
                
                result.innerText = "Sugestão da IA: " + refinedText;
                result.classList.remove('hidden');
            } catch (e) {
                result.innerText = "Não foi possível refinar no momento. Sua ideia foi salva!";
                result.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btn.innerText = "Melhorar com IA ✨";
            }
        }

        // --- GEMINI INTEGRATION: TEXT-TO-SPEECH ✨ ---
        async function speakAction(text) {
            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        model: "gemini-2.5-flash-preview-tts",
                        contents: [{ parts: [{ text: "Diga com tom profissional e calmo: " + text }] }],
                        generationConfig: {
                            responseModalities: ["AUDIO"],
                            speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Kore" } } }
                        }
                    })
                });

                const data = await response.json();
                const pcmData = data.candidates[0].content.parts[0].inlineData.data;
                const audioBlob = pcmToWav(pcmData, 24000); // 24kHz é padrão do modelo
                const audioUrl = URL.createObjectURL(audioBlob);
                const audio = new Audio(audioUrl);
                audio.play();
            } catch (e) {
                console.error("Erro no TTS", e);
            }
        }

        // Helper para converter PCM16 em WAV
        function pcmToWav(base64Pcm, sampleRate) {
            const buffer = Uint8Array.from(atob(base64Pcm), c => c.charCodeAt(0)).buffer;
            const wavHeader = new ArrayBuffer(44);
            const view = new DataView(wavHeader);
            const writeString = (offset, string) => { for (let i = 0; i < string.length; i++) view.setUint8(offset + i, string.charCodeAt(i)); };

            writeString(0, 'RIFF');
            view.setUint32(4, 32 + buffer.byteLength, true);
            writeString(8, 'WAVE');
            writeString(12, 'fmt ');
            view.setUint32(16, 16, true);
            view.setUint16(20, 1, true); // PCM
            view.setUint16(22, 1, true); // Mono
            view.setUint32(24, sampleRate, true);
            view.setUint32(28, sampleRate * 2, true);
            view.setUint16(32, 2, true);
            view.setUint16(34, 16, true);
            writeString(36, 'data');
            view.setUint32(40, buffer.byteLength, true);

            return new Blob([wavHeader, buffer], { type: 'audio/wav' });
        }

        // Outras UI Helpers
        function showEstrategia(titulo, desc) {
            document.getElementById('estrategiaDesc').innerHTML = `<h4 class="font-bold text-blue-800">${titulo}</h4><p class="text-xs text-blue-900">${desc}</p>`;
        }

        function showActionDetails(title, desc, resp, ind) {
            // Reaproveita o FAQ ou cria um alerta simples já que o foco é IA
            alert(`${title}\n\nResponsável: ${resp}\nIndicador: ${ind}`);
        }

        // Inicia reveal
        reveal();
    </script>
