            --mt-azul: #003366;
            --mt-cinza-claro: #F4F7F9;
            --mt-branco: #FFFFFF;
            --mt-accent: #0056b3;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--mt-branco);
            color: #333;
            scroll-behavior: smooth;
        }

        .bg-azul-mt { background-color: var(--mt-azul); }
        .text-azul-mt { color: var(--mt-azul); }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }
        .reveal.active {
